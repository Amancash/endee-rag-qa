# ── Endee Vector Database ──────────────────────────────────────
ENDEE_HOST=localhost
ENDEE_PORT=8080
# ENDEE_API_KEY=your_endee_api_key_here   # uncomment if auth is enabled

# ── Embedding Model ────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Set to "true" to skip sentence-transformers and use a fast mock embedder
USE_MOCK_EMBEDDER=false

# ── LLM (OpenAI-compatible) ────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-3.5-turbo
# For Groq: set LLM_MODEL=llama3-8b-8192 and point base URL to https://api.groq.com/openai/v1
# For Ollama: set LLM_MODEL=llama3 and base URL to http://localhost:11434/v1
